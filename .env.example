# Конфигурация приложения ООО "ЭТАЖИ"
# Скопируйте этот файл в .env и заполните своими данными

# Секретный ключ (обязательно)
SECRET_KEY=change-this-to-a-random-long-secret

# Пароль админ-панели (обязательно)
ADMIN_PASSWORD=change-this-admin-password

# Настройки почты для отправки уведомлений
MAIL_SERVER=smtp.mail.ru
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@mail.ru
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=your-email@mail.ru

# Email администратора для получения уведомлений
ADMIN_EMAIL=your-email@mail.ru

# Яндекс Метрика (опционально)
# Пример: YANDEX_METRIKA_ID=12345678
YANDEX_METRIKA_ID=

# Публичные данные компании (для шаблонов сайта)
COMPANY_CITY=Санкт-Петербург
COMPANY_ADDRESS=198320, г. Санкт-Петербург, пр-кт Ленина, д. 77 литера А, этаж 4, офис 418
COMPANY_INN=7807250523
COMPANY_OGRN=1217800123420
COMPANY_WORK_HOURS=Пн-Пт: 9:00 - 18:00

# Вариант дизайна: classic | futuristic
DESIGN_VARIANT=classic

# Видео для hero-блока (опционально):
# - локальный файл в static, например videos/hero.mp4
# - или полный URL, например https://cdn.example.com/hero.mp4
# HERO_VIDEO_ENABLED включает/выключает рендер видео в hero
HERO_VIDEO_ENABLED=false
HERO_VIDEO_PATH=

# Фоновое изображение hero (опционально):
# - локальный файл в static, например uploads/hero-elevator.jpg
# - или полный URL
HERO_IMAGE_PATH=

# Прод-режим Flask
FLASK_DEBUG=false
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
STATIC_ASSETS_CACHE_MAX_AGE=604800
ARTICLE_UPLOADS_CACHE_MAX_AGE=86400

# CSP режим (для production рекомендуется false после проверки)
CSP_REPORT_ONLY=true
# Пример endpoint: https://your-domain.ru/csp-report
CSP_REPORT_URI=

# Sentry (опционально)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Базовый rate-limit (без Redis) для защиты форм
ADMIN_LOGIN_RATE_LIMIT_COUNT=12
ADMIN_LOGIN_RATE_LIMIT_WINDOW=300
CONTACTS_RATE_LIMIT_COUNT=5
CONTACTS_RATE_LIMIT_WINDOW=600

# URL базы данных (опционально, по умолчанию используется SQLite)
# DATABASE_URL=postgresql://user:password@localhost/etazhi
